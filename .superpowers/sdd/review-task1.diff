+      </span>
+
+      <button
+        onClick={handleLoopToggle}
+        style={{ color: loop ? 'var(--accent)' : 'var(--muted)', borderColor: loop ? 'var(--accent)' : 'var(--muted)' }}
+      >
+        ↻
+      </button>
+    </div>
+  );
