+      </button>
+
+      <input
+        type="range"
+        min={0}
+        max={duration || 1}
+        step={0.1}
+        value={currentTime}
+        onChange={handleScrub}
+        style={{ flex: 1, maxWidth: 320, cursor: 'pointer' }}
+        disabled={duration === 0}
+      />
+
+      <span style={{ color: 'var(--muted)', whiteSpace: 'nowrap' }}>
